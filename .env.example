# Supabase Postgres connection string (Project Settings -> Database -> Connection string -> URI)
# Use the "Transaction" pooler mode URI for server-side apps, or "Session" for direct connection.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Years of history to fetch on a ticker's first run (default: 3)
INGESTION_INITIAL_BACKFILL_YEARS=3

# Days of price history loaded before recomputing indicators on incremental runs (default: 90)
INDICATOR_WARMUP_DAYS=90

# Optional: override path to tickers config inside the container
# TICKERS_CONFIG_PATH=/app/ingestion/config/tickers.yaml

# Cron schedule (default: weekdays at 22:00 UTC)
# INGESTION_CRON=0 22 * * 1-5

# Run ingestion once when the container starts (default: true)
# RUN_ON_STARTUP=true

# On Windows, curl_cffi often fails TLS verification against Yahoo Finance.
# The ingestion fetcher sets this automatically; override only if needed.
# YF_DISABLE_CURL_CFFI=1

# MLflow tracking server (default: local Docker service)
MLFLOW_TRACKING_URI=http://localhost:5000

# Forecast horizon in trading days (default: 7)
# FORECAST_HORIZON_DAYS=7

# Chronological train fraction for holdout evaluation (default: 0.8)
# TRAIN_TEST_SPLIT=0.8

# Prophet prediction interval width (default: 0.80 = 80% CI)
# PROPHET_INTERVAL_WIDTH=0.80

# Minimum rows required after feature warmup (default: 60)
# MIN_TRAINING_ROWS=60
